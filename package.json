{
  "name": "mineradio",
  "productName": "Mineradio",
  "version": "1.1.5",
  "description": "沉浸式音乐播放器，融合天气电台、歌词舞台、粒子视觉和 3D 歌单架。",
  "author": "Mineradio",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win nsis",
    "build:win:dir": "electron-builder --win dir",
    "prepare:mac": "bash build/macos/prepare.sh",
    "build:mac": "npm run prepare:mac && electron-builder --mac dmg zip --arm64",
    "build:mac:dir": "npm run prepare:mac && electron-builder --mac dir --arm64",
    "build:mac:arm64": "npm run prepare:mac && electron-builder --mac dmg zip --arm64"
  },
  "build": {
    "appId": "com.mineradio.desktop",
    "productName": "Mineradio",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.js",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "build/**/*",
      "server.js",
      "dj-analyzer.js",
      "package.json",
      "!public/index.*.html",
      "public/index.html"
    ],
    "asar": false,
    "win": {
      "executableName": "Mineradio",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mineradio",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh",
      "artifactName": "Mineradio-${version}-Setup.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "IFPrice",
        "repo": "Mineradio"
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "Mineradio-${version}-mac-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/macos/entitlements.mac.plist",
      "entitlementsInherit": "build/macos/entitlements.mac.plist",
      "extendInfo": {
        "NSHighResolutionCapable": true,
        "NSRequiresAquaSystemAppearance": false,
        "NSHumanReadableCopyright": "Copyright © 2026 XxHuberrr. GPL-3.0 source port for macOS."
      },
      "extraResources": [
        {
          "from": "build/macos/bin/mineradio-middle-click-helper",
          "to": "bin/mineradio-middle-click-helper"
        }
      ],
      "minimumSystemVersion": "13.0"
    },
    "dmg": {
      "title": "Mineradio ${version}",
      "artifactName": "Mineradio-${version}-mac-${arch}.${ext}",
      "sign": false
    }
  },
  "mineradio": {
    "update": {
      "provider": "github",
      "owner": "IFPrice",
      "repo": "Mineradio",
      "preview": true,
      "preferMirrors": true,
      "mirrors": [
        "https://gh.llkk.cc/",
        "https://ghfast.top/",
        "https://gh-proxy.com/"
      ]
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3",
    "NeteaseCloudMusicApi": "^4.32.0"
  },
  "devDependencies": {
    "electron": "38.6.0",
    "electron-builder": "^26.15.3",
    "rcedit": "^5.0.2"
  }
}
